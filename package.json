{
  "name": "copilot-custom-bridge",
  "displayName": "Copilot Custom Bridge",
  "description": "在 Copilot Chat 中使用 OpenAI 兼容的第三方模型",
  "version": "0.0.1",
  "publisher": "patrick-rex",
  "icon": "resources/icon.svg",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/Patrick-Rex/CopilotCustomBridge"
  },
  "keywords": [
    "copilot",
    "openai",
    "custom-model",
    "chat",
    "bridge"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copilot-custom-bridge.setApiKey",
        "title": "%command.setApiKey%",
        "category": "Copilot Custom Bridge"
      },
      {
        "command": "copilot-custom-bridge.clearApiKey",
        "title": "%command.clearApiKey%",
        "category": "Copilot Custom Bridge"
      },
      {
        "command": "copilot-custom-bridge.detectModels",
        "title": "%command.detectModels%",
        "category": "Copilot Custom Bridge"
      },
      {
        "command": "copilot-custom-bridge.openDumpDirectory",
        "title": "%command.openDumpDirectory%",
        "category": "Copilot Custom Bridge"
      },
      {
        "command": "copilot-custom-bridge.gettingStarted",
        "title": "%command.gettingStarted%",
        "category": "Copilot Custom Bridge"
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "copilot-custom-bridge",
        "displayName": "Copilot Custom Bridge"
      }
    ],
    "configuration": {
      "title": "Copilot Custom Bridge",
      "properties": {
        "copilot-custom-bridge.endpoints": {
          "type": "array",
          "default": [],
          "description": "%config.endpoints%",
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "baseUrl",
              "models"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-zA-Z0-9-]+$",
                "description": "%config.endpoints.items.id%"
              },
              "name": {
                "type": "string",
                "description": "%config.endpoints.items.name%"
              },
              "baseUrl": {
                "type": "string",
                "description": "%config.endpoints.items.baseUrl%"
              },
              "defaultHeaders": {
                "type": "object",
                "description": "%config.endpoints.items.defaultHeaders%"
              },
              "visionProxy": {
                "type": "string",
                "description": "%config.endpoints.items.visionProxy%"
              },
              "defaultThinkingEffort": {
                "type": "string",
                "enum": [
                  "none",
                  "minimal",
                  "low",
                  "medium",
                  "high",
                  "max"
                ],
                "description": "%config.endpoints.items.defaultThinkingEffort%"
              },
              "models": {
                "type": "array",
                "minItems": 0,
                "description": "%config.endpoints.items.models%",
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "name"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "%config.endpoints.items.models.items.id%"
                    },
                    "name": {
                      "type": "string",
                      "description": "%config.endpoints.items.models.items.name%"
                    },
                    "family": {
                      "type": "string",
                      "description": "%config.endpoints.items.models.items.family%"
                    },
                    "version": {
                      "type": "string",
                      "description": "%config.endpoints.items.models.items.version%"
                    },
                    "maxInputTokens": {
                      "type": "number",
                      "default": 4096,
                      "description": "%config.endpoints.items.models.items.maxInputTokens%"
                    },
                    "maxOutputTokens": {
                      "type": "number",
                      "default": 4096,
                      "description": "%config.endpoints.items.models.items.maxOutputTokens%"
                    },
                    "toolCalling": {
                      "type": [
                        "boolean",
                        "number"
                      ],
                      "default": false,
                      "description": "%config.endpoints.items.models.items.capabilities.toolCalling%"
                    },
                    "vision": {
                      "type": "boolean",
                      "default": false,
                      "description": "%config.endpoints.items.models.items.capabilities.vision%"
                    },
                    "thinking": {
                      "type": "boolean",
                      "default": false,
                      "description": "%config.endpoints.items.models.items.capabilities.thinking%"
                    },
                    "supportsReasoningEffort": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": [
                          "none",
                          "minimal",
                          "low",
                          "medium",
                          "high",
                          "max"
                        ]
                      },
                      "description": "%config.endpoints.items.models.items.capabilities.supportsReasoningEffort%"
                    },
                    "capabilities": {
                      "type": "object",
                      "properties": {
                        "toolCalling": {
                          "type": [
                            "boolean",
                            "number"
                          ],
                          "default": false
                        },
                        "imageInput": {
                          "type": "boolean",
                          "default": false
                        },
                        "vision": {
                          "type": "boolean",
                          "default": false,
                          "description": "%config.endpoints.items.models.items.capabilities.vision%"
                        },
                        "thinking": {
                          "type": "boolean",
                          "default": false
                        },
                        "supportsReasoningEffort": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": [
                              "none",
                              "minimal",
                              "low",
                              "medium",
                              "high",
                              "max"
                            ]
                          },
                          "description": "%config.endpoints.items.models.items.capabilities.supportsReasoningEffort%"
                        },
                        "visionProxy": {
                          "type": "string",
                          "description": "%config.endpoints.items.models.items.capabilities.visionProxy%"
                        },
                        "thinkingEffort": {
                          "type": "string",
                          "enum": [
                            "none",
                            "minimal",
                            "low",
                            "medium",
                            "high",
                            "max"
                          ],
                          "description": "%config.endpoints.items.models.items.capabilities.thinkingEffort%"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "copilot-custom-bridge.apiKey": {
          "type": "string",
          "default": "",
          "description": "%config.apiKey%"
        },
        "copilot-custom-bridge.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumDescriptions": [
            "%config.debugMode.minimal%",
            "%config.debugMode.metadata%",
            "%config.debugMode.verbose%"
          ],
          "description": "%config.debugMode%"
        },
        "copilot-custom-bridge.modelIdOverrides": {
          "type": "object",
          "default": {},
          "description": "%config.modelIdOverrides%"
        },
        "copilot-custom-bridge.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "%config.maxTokens%"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "copilot-custom-bridge.getting-started",
        "title": "%walkthrough.title%",
        "description": "%walkthrough.description%",
        "steps": [
          {
            "id": "configureEndpoint",
            "title": "%walkthrough.step1.title%",
            "description": "%walkthrough.step1.description%",
            "media": {
              "markdown": "resources/walkthrough/step1-endpoint.md"
            },
            "completionEvents": [
              "onCommand:workbench.action.openSettingsJson"
            ]
          },
          {
            "id": "setApiKey",
            "title": "%walkthrough.step2.title%",
            "description": "%walkthrough.step2.description%",
            "media": {
              "markdown": "resources/walkthrough/step2-apikey.md"
            },
            "completionEvents": [
              "copilot-custom-bridge:apiKeySet"
            ]
          },
          {
            "id": "switchModel",
            "title": "%walkthrough.step3.title%",
            "description": "%walkthrough.step3.description%",
            "media": {
              "markdown": "resources/walkthrough/step3-model.md"
            },
            "completionEvents": [
              "onCommand:workbench.action.chat.open"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.4.1",
    "mocha": "^10.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.0"
  }
}
